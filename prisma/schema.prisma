generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/"
}

datasource db {
  provider = "mysql"
}

model customers {
  id         String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(20)
  address    String?   @default("") @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  orders     orders[]

  @@index([phone], map: "idx_customers_phone")
}

model order_audit_log {
  id         String    @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  order_id   String?   @db.VarChar(36)
  user_id    String?   @db.VarChar(36)
  old_status String?   @db.VarChar(20)
  new_status String    @db.VarChar(20)
  notes      String?   @default("") @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
  orders     orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "idx_order_id")
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "idx_user_id")

  @@index([order_id], map: "idx_audit_order")
  @@index([user_id], map: "idx_user_id")
}

model orders {
  id                 String              @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  order_code         String              @unique(map: "order_code") @db.VarChar(50)
  customer_id        String?             @db.VarChar(36)
  service_type       orders_service_type
  quantity           Decimal             @default(0.00) @db.Decimal(10, 2)
  is_express         Boolean?            @default(false)
  base_price         Decimal             @default(0.00) @db.Decimal(10, 2)
  express_surcharge  Decimal?            @default(0.00) @db.Decimal(10, 2)
  total_price        Decimal             @default(0.00) @db.Decimal(10, 2)
  status             orders_status       @default(received)
  is_overdue         Boolean?            @default(false)
  needs_weight_label Boolean?            @default(false)
  condition_notes    String?             @default("") @db.Text
  notes              String?             @default("") @db.Text
  estimated_done     DateTime?           @db.Timestamp(0)
  created_by         String?             @db.VarChar(36)
  created_at         DateTime?           @default(now()) @db.Timestamp(0)
  updated_at         DateTime?           @default(now()) @db.Timestamp(0)
  picked_up_at       DateTime?           @db.Timestamp(0)
  order_audit_log    order_audit_log[]
  customers          customers?          @relation(fields: [customer_id], references: [id], onUpdate: Restrict, map: "fk_customer_id")
  payments           payments[]

  @@index([created_at], map: "idx_orders_created_at")
  @@index([customer_id], map: "idx_orders_customer")
  @@index([status], map: "idx_orders_status")
}

model payments {
  id       String          @id @default(dbgenerated("(uuid())")) @db.Char(70)
  order_id String          @db.Char(70)
  method   payments_method
  amount   Decimal         @db.Decimal(12, 0)
  paid_by  String?         @db.VarChar(100)
  paid_at  DateTime?       @default(now()) @db.DateTime(0)
  notes    String?         @db.VarChar(100)
  orders   orders          @relation(fields: [order_id], references: [id], onUpdate: Restrict, map: "fk_order_id")

  @@index([order_id], map: "fk_order_id")
}

model service_prices {
  id             String                      @id @default(dbgenerated("(uuid())")) @db.VarChar(36)
  service_type   service_prices_service_type @unique(map: "service_type")
  price_per_unit Decimal                     @default(0.00) @db.Decimal(10, 2)
  unit_label     String                      @default("") @db.VarChar(20)
  updated_at     DateTime?                   @default(now()) @db.Timestamp(0)
}

model users {
  id              String            @id @default(dbgenerated("(uuid())")) @db.Char(70)
  email           String            @unique(map: "email") @db.VarChar(100)
  password_hash   String            @db.Char(200)
  role            users_role        @default(karyawan)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.DateTime(0)
  order_audit_log order_audit_log[]
}

enum service_prices_service_type {
  kiloan
  satuan
  meter
}

enum payments_method {
  cash
  transfer
  qris
}

enum users_role {
  owner
  karyawan
}

enum orders_service_type {
  kiloan
  satuan
  express
  meter
}

enum orders_status {
  received
  washing
  ready
  picked_up
}
