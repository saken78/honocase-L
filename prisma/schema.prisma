generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/"
}

datasource db {
  provider = "mysql"
}

model customers {
  id           String    @id @default(dbgenerated("(uuid())")) @db.Char(70)
  name         String    @db.VarChar(200)
  phone        String    @db.VarChar(200)
  address      String?   @db.VarChar(200)
  total_orders Int?      @default(0) @db.SmallInt
  created_at   DateTime? @default(now()) @db.DateTime(0)
  updated_at   DateTime? @default(now()) @db.DateTime(0)
  orders       orders[]
}

model orders {
  id                  String          @id @default(dbgenerated("(uuid())")) @db.Char(200)
  order_code          String          @unique(map: "order_code") @db.Char(100)
  customer_id         String          @db.Char(70)
  service_id          String          @db.Char(70)
  quantity            orders_quantity
  base_subtotal       Decimal         @db.Decimal(12, 0)
  is_express          Boolean?        @default(false)
  express_fee_percent Decimal?        @default(50) @db.Decimal(12, 0)
  express_fee_amount  Decimal?        @db.Decimal(12, 0)
  discount            Decimal?        @default(0) @db.Decimal(12, 0)
  total               Decimal         @db.Decimal(12, 0)
  status              orders_status?  @default(received)
  notes               String?         @db.VarChar(100)
  pre_condition       String?         @db.VarChar(100)
  created_at          DateTime?       @default(now()) @db.DateTime(0)
  expected_ready_at   DateTime        @db.DateTime(0)
  actual_ready_at     DateTime?       @db.DateTime(0)
  picked_up_at        DateTime?       @db.DateTime(0)
  unclaimed_since     DateTime?       @db.DateTime(0)
  auction_date        DateTime?       @db.DateTime(0)
  auction_price       Decimal?        @db.Decimal(12, 0)
  needs_label         Boolean?
  customers           customers       @relation(fields: [customer_id], references: [id], onUpdate: Restrict, map: "fk_customer_id")
  services            services        @relation(fields: [service_id], references: [id], onUpdate: Restrict, map: "fk_service_id")
  payments            payments[]

  @@index([customer_id], map: "fk_customer_id")
  @@index([service_id], map: "fk_service_id")
}

model payments {
  id       String          @id @default(dbgenerated("(uuid())")) @db.Char(70)
  order_id String          @db.Char(70)
  method   payments_method
  amount   Decimal         @db.Decimal(12, 0)
  paid_by  String?         @db.VarChar(100)
  paid_at  DateTime?       @default(now()) @db.DateTime(0)
  notes    String?         @db.VarChar(100)
  orders   orders          @relation(fields: [order_id], references: [id], onUpdate: Restrict, map: "fk_order_id")

  @@index([order_id], map: "fk_order_id")
}

model services {
  id                       String                 @id @default(dbgenerated("(uuid())")) @db.Char(70)
  name                     String                 @db.VarChar(200)
  base_price               Decimal                @db.Decimal(10, 0)
  pricing_type             services_pricing_type?
  unit_label               services_unit_label?
  default_turnaround_hours Int?                   @db.SmallInt
  is_active                Boolean?               @default(true)
  created_at               DateTime?              @default(now()) @db.DateTime(0)
  orders                   orders[]
}

model users {
  id            String     @id @default(dbgenerated("(uuid())")) @db.Char(70)
  email         String     @unique(map: "email") @db.VarChar(100)
  firstname     String     @db.VarChar(100)
  lastname      String?    @db.VarChar(100)
  password_hash String     @db.Char(200)
  role          users_role
  is_active     Boolean?   @default(true)
  created_at    DateTime?  @default(now()) @db.DateTime(0)
}

enum payments_method {
  cash
  transfer
  qris
}

enum services_pricing_type {
  weight
  item
  fixed
}

enum services_unit_label {
  kg
  pcs
  EMPTY_ENUM_VALUE @map("")
}

enum users_role {
  owner
  staff
}

enum orders_quantity {
  kg
  pcs
}

enum orders_status {
  received
  washing
  ready
  picked_up
  auctioned
}
